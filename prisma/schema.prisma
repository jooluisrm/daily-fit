// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

// ====================================
// Auth.js (NextAuth) Models
// ====================================

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ====================================
// Application Models
// ====================================

model User {
  id            String    @id @default(cuid())
  // O Auth.js por padrão pede o 'name', manteremos para compatibilidade
  name          String?
  firstName     String?
  lastName      String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?   // Para login com credenciais
  
  // Campos de controle
  termsAccepted Boolean   @default(false)

  // Métricas Físicas do MVP (opcionais, preenchidos depois)
  age           Int?
  gender        String?
  height        Float?    // em cm
  weight        Float?    // em kg
  bmr           Float?    // Taxa Metabólica Basal (TMB) calculada
  
  accounts      Account[]
  sessions      Session[]
  workouts      Workout[]
  cardioLogs    CardioLog[]
  workoutLogs   WorkoutLog[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Workout {
  id          String   @id @default(cuid())
  userId      String
  name        String
  daysOfWeek  String   // Armazena JSON com os dias da semana (ex: "[1,3,5]")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  workoutExercises WorkoutExercise[]
  workoutLogs      WorkoutLog[]
}

model Exercise {
  id          String   @id @default(cuid())
  name        String
  imageUrl    String?
  createdAt   DateTime @default(now())

  workoutExercises WorkoutExercise[]
}

model WorkoutExercise {
  id          String   @id @default(cuid())
  workoutId   String
  exerciseId  String
  
  sets        Int
  reps        String
  order       Int      @default(0)
  isActive    Boolean  @default(true)

  workout     Workout  @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  exercise    Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  logs        ExerciseLog[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ExerciseLog {
  id                String   @id @default(cuid())
  workoutExerciseId String
  
  setNumber         Int      @default(1)
  weight            Float
  repsDone          Int
  date              DateTime @default(now())

  workoutExercise   WorkoutExercise @relation(fields: [workoutExerciseId], references: [id], onDelete: Cascade)
}

model CardioLog {
  id          String   @id @default(cuid())
  userId      String
  workoutId   String?
  
  intensity   String   // "leve", "moderado", "intenso"
  duration    Int      // em minutos
  date        DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WorkoutLog {
  id          String   @id @default(cuid())
  userId      String
  workoutId   String
  date        DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  workout     Workout  @relation(fields: [workoutId], references: [id], onDelete: Cascade)
}
